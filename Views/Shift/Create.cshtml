@model OrgMgmt.Models.Shift

@{
    ViewData["Title"] = "Create Shift";
}

<h1>Create Shift</h1>

<h4>Shift</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Location" class="control-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="StartTime" class="control-label"></label>
                <input asp-for="StartTime" type="time" class="form-control" />
                <span asp-validation-for="StartTime" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="EndTime" class="control-label"></label>
                <input asp-for="EndTime" type="time" class="form-control" />
                <span asp-validation-for="EndTime" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Frequency" class="control-label"></label>
                <select asp-for="Frequency" class="form-control" asp-items="Html.GetEnumSelectList<OrgMgmt.Models.Frequency>()"></select>
                <span asp-validation-for="Frequency" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Interval" class="control-label"></label>
                <select asp-for="Interval" class="form-control">
                    <option value="1">Weekly</option>
                    <option value="2">Bi-weekly</option>
                </select>
                <span asp-validation-for="Interval" class="text-danger"></span>
            </div>
            <div class="form-group mb-4">
                <label asp-for="DaysOfWeek" class="control-label">Days (e.g., Mon,Tue)</label>
                <input asp-for="DaysOfWeek" class="form-control" />
                <span asp-validation-for="DaysOfWeek" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
