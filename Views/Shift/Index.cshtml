@model IEnumerable<OrgMgmt.Models.Shift>

@{
    ViewData["Title"] = "Shifts";
}

<h1>Shifts</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Shift</a>
    <a asp-action="Assign" class="btn btn-secondary">Assign Shifts</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.Location)</th>
            <th>@Html.DisplayNameFor(model => model.StartTime)</th>
            <th>@Html.DisplayNameFor(model => model.EndTime)</th>
            <th>@Html.DisplayNameFor(model => model.Frequency)</th>
            <th>Interval</th>
            <th>@Html.DisplayNameFor(model => model.DaysOfWeek)</th>
            <th>Duration</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Name)</td>
            <td>@Html.DisplayFor(modelItem => item.Location)</td>
            <td>@item.StartTime.ToString(@"hh\:mm")</td>
            <td>@item.EndTime.ToString(@"hh\:mm")</td>
            <td>@Html.DisplayFor(modelItem => item.Frequency)</td>
            <td>@(item.Interval == 2 ? "Bi-weekly" : "Weekly")</td>
            <td>@Html.DisplayFor(modelItem => item.DaysOfWeek)</td>
            <td>@item.Duration.ToString(@"hh\:mm")</td>
        </tr>
}
    </tbody>
</table>
