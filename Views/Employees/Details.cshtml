@model OrgMgmt.Models.Employee

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Employee</h4>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Name)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Role)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Role)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.IsActive)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.IsActive)
                </dd>
                @if (ViewBag.CanViewFinancialData == true)
                {
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.HourlyPayRate)
                </dt>
                <dd class="col-sm-8">
                    @* Formats hourly pay rate as currency *@
                    @Model.HourlyPayRate.ToString("C")
                </dd>
                }
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.Address)
                </dt>
                <dd class="col-sm-8">
                    @Html.DisplayFor(model => model.Address)
                </dd>
                <dt class="col-sm-4">
                    @Html.DisplayNameFor(model => model.DateOfBirth)
                </dt>
                <dd class="col-sm-8">
                    @* Handles null Date of Birth requirement [0.5 marks] *@
                    @(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToShortDateString() : "Not Provided")
                </dd>
            </dl>
        </div>

        @* Photo Section - Handles null Photo requirement [0.5 marks] *@
        <div class="col-md-4 text-center">
            <h6>Employee Photo</h6>
            @if (Model.Photo != null && Model.Photo.Length > 0)
            {
                <img src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Photo)" 
                     class="img-thumbnail rounded" 
                     style="max-width: 100%; height: auto; max-height: 300px;" 
                     alt="Employee Photo" />
            }
            else
            {
                <div class="border rounded d-flex align-items-center justify-content-center bg-light" 
                     style="height: 200px; width: 200px; margin: 0 auto;">
                    <span class="text-muted">No Photo</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.ID" >Edit</a> |
    <a asp-action="Index" >Back to List</a>
</div>
